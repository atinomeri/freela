# Phase 4 overlay env for mailer split (`docker-compose.phase4.yml`)
# Copy to `deploy/.env.phase4` and fill real secrets before launch.

# Mailer service routing
MAILER_UPSTREAM=mailer-app:3000
MAILER_PUBLIC_URL=https://freela.ge

# Mailer isolated storage
MAILER_DATABASE_URL=postgresql://freela:replace-with-strong-db-password@mailer-db:5432/freela?schema=public
MAILER_REDIS_URL=redis://mailer-redis:6379

# Redis namespacing (avoid collisions with freela app keys)
RATE_LIMIT_KEY_PREFIX_MAILER=mailer:
RATE_LIMIT_KEY_PREFIX_FREELA=freela:

# Mailer auth and crypto (must be set; do not commit real values)
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-secret
UNSUBSCRIBE_TOKEN_SECRET=replace-with-strong-secret
INTERNAL_API_SECRET=replace-with-strong-secret
SMTP_CONFIG_SECRET=replace-with-64-hex-chars
