generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYER
  FREELANCER
  ADMIN
}

enum EmployerType {
  INDIVIDUAL
  COMPANY
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  MESSAGE
  PROPOSAL_STATUS
  NEW_PROPOSAL
}

enum SupportThreadStatus {
  OPEN
  CLOSED
}

enum SupportMessageSenderRole {
  VISITOR
  USER
  ADMIN
}

enum FreelancerCategory {
  IT_DEVELOPMENT
  DESIGN_CREATIVE
  MARKETING_CONTENT
  FINANCE
  LOGISTICS
  BUSINESS_ADMIN
  CONSTRUCTION
  TRANSPORT
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String
  avatarUrl    String?
  email        String   @unique
  role         Role     @default(EMPLOYER)
  passwordHash String?
  emailVerifiedAt DateTime?
  isDisabled   Boolean  @default(false)
  disabledAt   DateTime?
  disabledReason String?
  projectEmailSubscribed Boolean @default(false)

  phone       String?
  personalId  String?   @unique
  birthDate   DateTime?
  employerType EmployerType?
  companyName String?
  companyId   String?   @unique

  profile  Profile?
  projects Project[] @relation("UserProjects")
  proposals Proposal[] @relation("UserProposals")
  employerThreads Thread[] @relation("EmployerThreads")
  freelancerThreads Thread[] @relation("FreelancerThreads")
  sentMessages Message[] @relation("MessageSender")
  supportRequestedThreads SupportThread[] @relation("SupportRequester")
  supportSentMessages SupportMessage[] @relation("SupportSender")
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  reviewsGiven    Review[] @relation("ReviewsGiven")
  reviewsReceived Review[] @relation("ReviewsReceived")
  approvedReviews Review[] @relation("ReviewsApproved")
  pushSubscriptions PushSubscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category FreelancerCategory?

  city  String?
  title String?
  bio   String?
  rate  String?
  hourlyGEL Int?

  skills    Json?
  tags      Json?
  portfolio Json?

  isPremium Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Project {
  id String @id @default(cuid())

  employerId String
  employer   User   @relation("UserProjects", fields: [employerId], references: [id], onDelete: Cascade)

  category FreelancerCategory?

  title       String
  description String

  city   String
  budgetGEL Int?
  tags      Json?

  isOpen Boolean @default(true)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proposals Proposal[]
  threads Thread[]
  reviews Review[]

  @@index([employerId])
  @@index([city])
  @@index([category])
  @@index([completedAt])
}

model Proposal {
  id           String   @id @default(cuid())
  projectId    String
  freelancerId String
  message      String
  priceGEL     Int?
  status       ProposalStatus @default(PENDING)
  createdAt    DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer User    @relation("UserProposals", fields: [freelancerId], references: [id], onDelete: Cascade)

  @@unique([projectId, freelancerId])
  @@index([projectId])
  @@index([freelancerId])
}

model Thread {
  id           String   @id @default(cuid())
  projectId    String
  employerId   String
  freelancerId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employer   User    @relation("EmployerThreads", fields: [employerId], references: [id], onDelete: Cascade)
  freelancer User    @relation("FreelancerThreads", fields: [freelancerId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([projectId, freelancerId])
  @@index([employerId])
  @@index([freelancerId])
}

model SupportThread {
  id        String   @id @default(cuid())
  status    SupportThreadStatus @default(OPEN)

  requesterUserId String?
  requesterUser   User?   @relation("SupportRequester", fields: [requesterUserId], references: [id], onDelete: SetNull)
  requesterName   String?
  requesterEmail  String?

  visitorTokenHash String? @unique

  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages SupportMessage[]

  @@index([status, lastMessageAt])
  @@index([requesterUserId])
}

model SupportMessage {
  id        String   @id @default(cuid())
  threadId  String
  senderRole SupportMessageSenderRole
  senderUserId String?
  senderUser User? @relation("SupportSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  body      String
  createdAt DateTime @default(now())

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([senderUserId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User   @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  attachments MessageAttachment[]

  @@index([threadId])
  @@index([senderId])
  @@index([threadId, deliveredAt])
  @@index([threadId, readAt])
}

model MessageAttachment {
  id           String   @id @default(cuid())
  messageId    String
  originalName String
  storagePath  String
  mimeType     String?
  sizeBytes    Int
  createdAt    DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String
  locale    String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([key])
  @@index([locale])
}

model SitePage {
  id        String   @id @default(cuid())
  path      String   @unique
  isEnabled Boolean  @default(true)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contents SitePageContent[]

  @@index([path])
}

model SitePageContent {
  id        String   @id @default(cuid())
  pageId    String
  locale    String
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page SitePage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
  @@index([pageId])
  @@index([locale])
}

model Review {
  id          String   @id @default(cuid())
  projectId   String
  freelancerId String
  reviewerId  String
  rating      Int
  comment     String?
  isApproved  Boolean  @default(false)
  approvedAt  DateTime?
  approvedByUserId String?
  createdAt   DateTime @default(now())

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  freelancer User    @relation("ReviewsReceived", fields: [freelancerId], references: [id], onDelete: Cascade)
  reviewer   User    @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  approvedBy User?   @relation("ReviewsApproved", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, freelancerId])
  @@index([isApproved, createdAt])
  @@index([freelancerId, createdAt])
  @@index([reviewerId, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AppRelease {
  id            String   @id @default(uuid())
  version       String   @unique // например, "1.0.1"
  releaseNotes  String?  @db.Text
  downloadUrl   String   // путь к файлу, например "/downloads/sender-patch-1.0.1.zip"
  isMandatory   Boolean  @default(false) // Принудительное обновление
  isActive      Boolean  @default(true)  // Позволяет быстро "откатить" или скрыть релиз
  createdAt     DateTime @default(now())
}

model LicenseKey {
  id        String    @id @default(uuid())
  key       String    @unique
  tier      String    // "PRO" или "ENTERPRISE"
  hwid      String?   // Hardware ID привязанной машины
  isActive  Boolean   @default(true)
  expiresAt DateTime? // null = бессрочная
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([key])
  @@index([hwid])
}

model EmailTrackingEvent {
  id         String   @id @default(cuid())
  campaignId String?  // ID кампании рассылки
  email      String?  // Deprecated: will be removed after migration
  emailHash  String?  // SHA-256 hash of recipient email (PII protection)
  eventType  String   // 'OPEN' или 'CLICK'
  url        String?  // Куда кликнули (только для CLICK)
  userAgent  String?  // User-Agent браузера/клиента
  ipAddress  String?  // IP адрес для дополнительной аналитики
  createdAt  DateTime @default(now())

  @@index([campaignId, eventType])
  @@index([emailHash, eventType])
  @@index([createdAt])
}

model UnsubscribedEmail {
  id            String       @id @default(cuid())
  email         String
  source        String       @default("link")
  createdAt     DateTime     @default(now())

  // Desktop user who sent the campaign (nullable for legacy/web unsubscribes)
  desktopUserId String?
  desktopUser   DesktopUser? @relation(fields: [desktopUserId], references: [id], onDelete: SetNull)

  @@unique([email, desktopUserId]) // Same email can unsubscribe from multiple senders
  @@index([createdAt])
  @@index([desktopUserId])
}

// ════════════════════════════════════════════
// Desktop App — полностью отдельные таблицы
// ════════════════════════════════════════════

enum DesktopUserType {
  INDIVIDUAL
  COMPANY
}

enum DesktopLedgerEntryType {
  TOPUP
  QUOTA_RESERVE
  QUOTA_REFUND
  ADJUSTMENT
  PAYMENT_CAPTURE
  PAYMENT_REFUND
}

enum DesktopPaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELED
}

enum DesktopPaymentProvider {
  MANUAL
  STRIPE
  BOG
}

model DesktopUser {
  id            String          @id @default(cuid())
  userType      DesktopUserType

  // Физ. лицо
  firstName      String?
  lastName       String?
  personalNumber String?         @unique
  birthDate      DateTime?

  // Компания
  companyName    String?
  companyIdCode  String?         @unique

  // Общие
  phone         String
  email         String          @unique
  passwordHash  String
  balance       Int             @default(0)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  refreshTokens     DesktopRefreshToken[]
  quotas            DesktopQuota[]
  payments          DesktopPayment[]
  ledgerEntries     DesktopLedgerEntry[]
  campaignReports   CampaignReport[]
  campaigns         Campaign[]
  contactLists      ContactList[]
  unsubscribedEmails UnsubscribedEmail[]
  smtpConfig        DesktopSmtpConfig?
  campaignTemplates CampaignTemplate[]

  @@index([email])
}

model DesktopRefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      DesktopUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model DesktopSmtpConfig {
  id            String      @id @default(cuid())
  desktopUserId String      @unique
  desktopUser   DesktopUser @relation(fields: [desktopUserId], references: [id], onDelete: Cascade)

  host          String
  port          Int         @default(465)
  secure        Boolean     @default(true)
  username      String
  passwordEnc   String
  fromEmail     String?
  fromName      String?
  trackOpens    Boolean     @default(true)
  trackClicks   Boolean     @default(true)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model DesktopQuota {
  id         String   @id @default(cuid())
  userId     String
  user       DesktopUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  allowed    Int
  charged    Int
  sent       Int      @default(0)
  failed     Int      @default(0)
  refunded   Int      @default(0)
  status     String   @default("active") // active, reported, expired
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([status, expiresAt])
}

model DesktopPayment {
  id                 String                 @id @default(cuid())
  userId             String
  user               DesktopUser            @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount             Int
  currency           String                 @default("GEL")
  status             DesktopPaymentStatus   @default(PENDING)
  provider           DesktopPaymentProvider @default(MANUAL)
  externalPaymentId  String?
  metadata           Json?
  processedByAdminId String?
  completedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([externalPaymentId])
}

model DesktopLedgerEntry {
  id             String                @id @default(cuid())
  userId         String
  user           DesktopUser           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           DesktopLedgerEntryType
  amount         Int
  balanceBefore  Int
  balanceAfter   Int
  currency       String                @default("GEL")
  referenceType  String?
  referenceId    String?
  description    String?
  metadata       Json?
  idempotencyKey String?               @unique
  createdAt      DateTime              @default(now())

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
}

model CampaignReport {
  id             String       @id @default(uuid())
  campaignId     String       @unique
  desktopUserId  String?      // Owner — nullable for backward compat with old reports
  desktopUser    DesktopUser? @relation(fields: [desktopUserId], references: [id], onDelete: SetNull)
  hwid           String
  licenseKey     String?
  total          Int
  sent           Int
  failed         Int
  startedAt      DateTime
  finishedAt     DateTime
  events         Json?
  createdAt      DateTime     @default(now())

  @@index([desktopUserId])
}

model CampaignTemplate {
  id            String      @id @default(cuid())
  desktopUserId String
  desktopUser   DesktopUser @relation(fields: [desktopUserId], references: [id], onDelete: Cascade)

  name          String
  category      String      @default("custom")
  subject       String
  html          String      @db.Text
  description   String?     @db.Text

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([desktopUserId, createdAt])
}

// ════════════════════════════════════════════
// Campaign — server-side email campaigns
// ════════════════════════════════════════════

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  FAILED
}

model Campaign {
  id              String         @id @default(cuid())
  desktopUserId   String
  desktopUser     DesktopUser    @relation(fields: [desktopUserId], references: [id], onDelete: Cascade)

  name            String         // internal campaign name
  subject         String         // email subject line
  senderName      String?        // "From" display name
  senderEmail     String?        // "From" email override
  html            String         @db.Text  // email HTML body
  status          CampaignStatus @default(DRAFT)

  contactListId   String?
  contactList     ContactList?   @relation(fields: [contactListId], references: [id], onDelete: SetNull)

  scheduledAt     DateTime?      // optional future send time
  startedAt       DateTime?      // actual sending start
  completedAt     DateTime?      // sending finished

  totalCount      Int            @default(0)  // total recipients
  sentCount       Int            @default(0)  // successfully sent
  failedCount     Int            @default(0)  // failed deliveries

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([desktopUserId, createdAt])
  @@index([status])
}

// ════════════════════════════════════════════
// Contact Lists & Contacts
// ════════════════════════════════════════════

model ContactList {
  id              String       @id @default(cuid())
  desktopUserId   String
  desktopUser     DesktopUser  @relation(fields: [desktopUserId], references: [id], onDelete: Cascade)

  name            String
  columns         Json         // string[] — original CSV/XLSX column names
  emailColumn     String       // which column holds the email address
  contactCount    Int          @default(0)

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  contacts        Contact[]
  campaigns       Campaign[]

  @@index([desktopUserId, createdAt])
}

model Contact {
  id              String       @id @default(cuid())
  contactListId   String
  contactList     ContactList  @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  email           String
  data            Json?        // all other columns as key-value pairs for personalization

  createdAt       DateTime     @default(now())

  @@unique([contactListId, email])
  @@index([contactListId])
  @@index([email])
}
